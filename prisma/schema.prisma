generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  exchange  String?
  sector    String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cached API responses
  profileData       Json?
  profileFetchedAt  DateTime?
  metricsData       Json?
  metricsFetchedAt  DateTime?

  financials  Financials[]
  priceCache  PriceCache[]
}

model Financials {
  id          String   @id @default(cuid())
  companyId   String
  period      String   // "annual" | "quarterly"
  fiscalYear  Int
  fiscalQuarter Int?
  statement   String   // "income" | "balance" | "cashflow"
  data        Json
  fetchedAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, period, fiscalYear, fiscalQuarter, statement])
  @@index([companyId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
  @@index([userId])
}

model SavedComp {
  id        String   @id @default(cuid())
  userId    String
  name      String
  tickers   String[] // ordered list of tickers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PriceCache {
  id          String   @id @default(cuid())
  companyId   String
  date        DateTime
  open        Float
  high        Float
  low         Float
  close       Float
  volume      BigInt
  fetchedAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId, date])
}
